DISCORD_BOT_TOKEN=
DATABASE_URL=sqlite+aiosqlite:///./bot.db
TRANSLATION_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_TRANSLATION_MODEL=gpt-5.4-mini
OPENAI_TRANSLATION_QUALITY_MODEL=gpt-5.4-mini
GEMINI_API_KEY=
